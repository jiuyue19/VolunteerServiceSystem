# 环境变量配置文件
# 复制此文件为 .env 并填入实际的配置信息
# 注意：.env 文件不要提交到Git仓库！

# ========== RPC节点配置 ==========
# Sepolia 测试网 RPC URL（推荐使用 Infura 或 Alchemy）
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Goerli 测试网 RPC URL
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_PROJECT_ID

# 以太坊主网 RPC URL
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ========== 部署账户配置 ==========
# 部署账户的私钥（不要泄露！不要提交到Git！）
# 从MetaMask导出私钥：账户详情 -> 导出私钥
PRIVATE_KEY=your_private_key_here_without_0x_prefix

# ========== 区块链浏览器API配置 ==========
# Etherscan API Key（用于验证合约源码）
# 在 https://etherscan.io/myapikey 申请
ETHERSCAN_API_KEY=your_etherscan_api_key

# BSCScan API Key（如果部署到币安智能链）
# 在 https://bscscan.com/myapikey 申请
BSCSCAN_API_KEY=your_bscscan_api_key

# ========== Gas报告配置 ==========
# 是否启用Gas报告
REPORT_GAS=true

# CoinMarketCap API Key（用于Gas费用的USD价格）
# 在 https://coinmarketcap.com/api/ 申请
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# ========== 使用说明 ==========
# 1. 复制此文件为 .env
# 2. 填入实际的配置信息
# 3. 确保 .env 已添加到 .gitignore
# 4. 运行部署命令：npm run deploy:sepolia
