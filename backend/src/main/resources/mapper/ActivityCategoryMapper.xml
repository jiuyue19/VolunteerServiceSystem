<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.volunteer.mapper.ActivityCategoryMapper">

    <resultMap id="BaseResultMap" type="com.volunteer.entity.ActivityCategory">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="create_time"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM activity_category ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.volunteer.entity.ActivityCategory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO activity_category (name, description, create_time)
        VALUES (#{name}, #{description}, #{createdAt})
    </insert>

    <update id="update" parameterType="com.volunteer.entity.ActivityCategory">
        UPDATE activity_category
        SET name = #{name},
            description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM activity_category WHERE id = #{id}
    </delete>

</mapper>